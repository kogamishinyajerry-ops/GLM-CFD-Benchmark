// StarCCM+ NACA0012 mesh-convergence macro -- cfdb StarCCMAdapter
// STAR-CCM+ 2402 (19.02.009-R8) proven API paths
// Case: {{ case_id }}, Mach: {{ mach }}, Re: {{ reynolds }}, AoA: {{ alpha_deg }} deg
// Mesh: base_size={{ base_size | default('import') }}, prism={{ prism_layers | default(8) }}
{% if base_size is defined and base_size is number %}
// Auto-mesh mode -- geometry from {{ case_dir }}/naca0012.stl
{% else %}
// Import-mesh mode -- pre-built {{ case_dir }}/mesh.ccm
{% endif %}
// Generated: auto by cfdb

package macro;

import star.common.*;
import star.base.report.*;
import star.flow.*;
import star.meshing.*;
import star.turbulence.*;
import star.vis.*;
import java.util.*;
import java.io.*;

public class RunCase extends StarMacro {

    // --- Parameters (overridable via Jinja2 context) ---
{% if base_size is defined and base_size is number %}
    double BASE       = {{ base_size }};       // m -- base size for poly/trim mesh
    int    PRISM      = {{ prism_layers | default(8) }};  // number of prism layers
    double PRISM_THK  = {{ prism_thickness | default(0.002) }}; // m -- total prism thickness
    double SURF_MIN   = {{ surface_min | default(base_size * 0.1) }}; // m -- surface min
    double SURF_MAX   = {{ surface_max | default(base_size * 2.0) }}; // m -- surface max
{% endif %}
    int    ITERS      = {{ n_iter }};          // maximum solver iterations
    int    CELLS      = 0;                    // cell count (populated post-mesh)

    public void execute() {
        Simulation sim = getActiveSimulation();
        long t0 = System.currentTimeMillis();

{% if base_size is defined and base_size is number %}
        // === AUTO-MESH MODE ===
        // Phase A: Import geometry + generate mesh with parameterized sizing
        sim.getMeshManager().importMesh(resolvePath("{{ case_dir }}/naca0012.stl"));
        sim.println("NACA0012 geometry imported (auto-mesh mode, base=" + BASE + ")");

        // Enable auto-mesh defaults and set sizes via reflection (2402 R8 proven path)
        Object meshOp = sim.get(MeshOperationManager.class).getObject("Automated Mesh");
        if (meshOp == null) {
            MeshOperationManager mom = sim.get(MeshOperationManager.class);
            mom.createAutoMeshOperation();
            meshOp = mom.getObject("Automated Mesh");
        }

        // Base size
        try {
            Object def = meshOp.getClass().getMethod("getDefaultValues").invoke(meshOp);
            Object bs = def.getClass().getMethod("get", Class.class)
                .invoke(def, Class.forName("star.meshing.BaseSize"));
            bs.getClass().getMethod("setValue", double.class).invoke(bs, BASE);
            sim.println("BaseSize set to " + BASE + " m");
        } catch (Throwable t) {
            sim.println("WARNING: BaseSize set failed: " + t.getMessage());
        }

        // Surface sizing
        try {
            Object def = meshOp.getClass().getMethod("getDefaultValues").invoke(meshOp);
            Object ss = def.getClass().getMethod("get", Class.class)
                .invoke(def, Class.forName("star.meshing.SurfaceSizeOption"));
            if (ss != null) {
                ss.getClass().getMethod("setCustomSizeEnabled", boolean.class).invoke(ss, true);
                Object minSz = ss.getClass().getMethod("getMinSize").invoke(ss);
                Object maxSz = ss.getClass().getMethod("getMaxSize").invoke(ss);
                minSz.getClass().getMethod("setValue", double.class).invoke(minSz, SURF_MIN);
                maxSz.getClass().getMethod("setValue", double.class).invoke(maxSz, SURF_MAX);
                sim.println("Surface sizing: min=" + SURF_MIN + " max=" + SURF_MAX);
            }
        } catch (Throwable t) {
            sim.println("INFO: surface sizing skipped: " + t.getMessage());
        }

        // Prism layers (wall-resolved SA needs y+ ~1 for NACA0012)
        try {
            Object def = meshOp.getClass().getMethod("getDefaultValues").invoke(meshOp);
            Object npl = def.getClass().getMethod("get", Class.class)
                .invoke(def, Class.forName("star.prismmesher.NumPrismLayers"));
            npl.getClass().getMethod("setNumLayers", int.class).invoke(npl, PRISM);

            Object pt = def.getClass().getMethod("get", Class.class)
                .invoke(def, Class.forName("star.prismmesher.TotalThickness"));
            pt.getClass().getMethod("setValue", double.class).invoke(pt, PRISM_THK);
            sim.println("Prism layers: " + PRISM + " total_thickness=" + PRISM_THK + " m");
        } catch (Throwable t) {
            sim.println("INFO: prism settings skipped: " + t.getMessage());
        }

        // Generate volume mesh
        sim.println("Generating mesh (poly) base=" + BASE + " prism=" + PRISM + " ...");
        Object mpc = sim.get(MeshPipelineController.class);
        mpc.getClass().getMethod("generateVolumeMesh").invoke(mpc);

        CELLS = (int) sim.getMeshManager().getCellCount();
        sim.println("Mesh generated: " + CELLS + " cells (base_size=" + BASE + ")");

        // Set physics on first continuum
        PhysicsContinuum phys = sim.getPhysicsContinuumManager().getContinuum(0);
        phys.enable(GasModel.class);
        phys.enable(CoupledFlowModel.class);
        phys.enable(SteadyModel.class);
        phys.enable(TurbulentModel.class);
        phys.enable(RansTurbulenceModel.class);
        phys.enable(SpalartAllmarasTurbulence.class);
        phys.enable(IdealGasModel.class);

        // Freestream
        sim.getConditions().get(Velocity.class).setComponents({{ u_cos }}, {{ v_sin }}, 0.0);
        sim.getConditions().get(MachNumber.class).setValue({{ mach }});
        sim.getConditions().get(ReynoldsNumber.class).setValue({{ reynolds }});

        // Boundary conditions -- auto-mesh region naming
        Region region = sim.getRegionManager().getRegion("Region");
        Boundary wall = findWallBoundary(region);
        if (wall != null) {
            wall.getConditions().get(WallShearStressOption.class)
                .setSelected(WallShearStressOption.NO_SLIP);
        }
        Boundary farfield = findFarfieldBoundary(region);
        if (farfield != null) {
            farfield.setType(FreestreamBoundary.class);
        }

{% else %}
        // === IMPORT-MESH MODE (legacy fallback) ===
        sim.getMeshManager().importMesh(resolvePath("{{ case_dir }}/mesh.ccm"));
        sim.println("NACA0012 mesh imported from: {{ case_dir }}/mesh.ccm");

        PhysicsContinuum phys = sim.getPhysicsContinuumManager().getContinuum(0);
        phys.enable(GasModel.class);
        phys.enable(CoupledFlowModel.class);
        phys.enable(SteadyModel.class);
        phys.enable(TurbulentModel.class);
        phys.enable(RansTurbulenceModel.class);
        phys.enable(SpalartAllmarasTurbulence.class);
        phys.enable(IdealGasModel.class);

        sim.getConditions().get(Velocity.class).setComponents({{ u_cos }}, {{ v_sin }}, 0.0);
        sim.getConditions().get(MachNumber.class).setValue({{ mach }});
        sim.getConditions().get(ReynoldsNumber.class).setValue({{ reynolds }});

        Region region = sim.getRegionManager().getRegion("Region");
        Boundary wall = region.getBoundaryManager().getBoundary("airfoil");
        if (wall != null) {
            wall.getConditions().get(WallShearStressOption.class)
                .setSelected(WallShearStressOption.NO_SLIP);
        }
        Boundary farfield = region.getBoundaryManager().getBoundary("farfield");
        if (farfield != null) {
            farfield.setType(FreestreamBoundary.class);
        }

        CELLS = (int) sim.getMeshManager().getCellCount();
{% endif %}

        // --- Reference values ---
        ReferenceValues refVals = sim.getReferenceValues();
        refVals.setReferenceVelocity({{ u_inf }});
        refVals.setReferenceArea(1.0);
        refVals.setReferenceDensity(1.225);

        // --- Force coefficient report ---
        ForceCoefficientReport forceReport = sim.getReportManager()
            .createReport(ForceCoefficientReport.class);
        forceReport.setPresentationName("Force Coefficient NACA0012");
        if (wall != null) {
            forceReport.getParts().setObjects(wall);
        }

        MonitorPlot forcePlot = sim.getPlotManager()
            .createMonitorPlot("Force History");
        forcePlot.add(forceReport.getForceCoefficientMonitor().createDataSet());

        // --- Residual monitors ---
        MonitorPlot residualPlot = sim.getPlotManager()
            .createMonitorPlot("Residuals");
        ResidualMonitorIterator resIt = sim.getMonitorManager()
            .getResidualMonitorManager().getObjects().iterator();
        while (resIt.hasNext()) {
            ResidualMonitor rm = resIt.next();
            residualPlot.add(rm.createDataSet());
        }

        // --- Stopping criteria ---
        sim.getSolverStoppingCriterionManager()
            .getSolverStoppingCriterion("Maximum Steps")
            .setMaximumNumberSteps(ITERS);

        // --- Run solver ---
        sim.getSimulationIterator().run();
        long elapsed = System.currentTimeMillis() - t0;

        // --- Export forces.csv with mesh-convergence metadata ---
        try {
            // Coerce force history into a structured CSV
            sim.getReportManager().exportMonitor(forceReport,
                resolvePath("{{ case_dir }}/forces.csv"), ",");
            sim.println("Forces exported to forces.csv");
        } catch (Exception e) {
            // Fallback: write synthetic CSV with final coefficients
            try {
                FileWriter fw = new FileWriter(resolvePath("{{ case_dir }}/forces.csv"));
                fw.write("Iteration,Cd,Cl\n");
                double cd = forceReport.getForceCoefficientMonitor().getMonitorValue();
                fw.write("final," + forceReport.getDragCoefficient().getValue() + ","
                    + forceReport.getLiftCoefficient().getValue() + "\n");
                fw.close();
                sim.println("Synthetic forces.csv written");
            } catch (Exception e2) {
                sim.println("WARNING: force CSV export failed: " + e2.getMessage());
            }
        }

        // --- Export mesh-convergence summary JSON ---
        try {
            FileWriter fw = new FileWriter(
                resolvePath("{{ case_dir }}/mesh_conv_summary.json"));
            fw.write("{");
{% if base_size is defined and base_size is number %}
            fw.write("\"base_size_m\": " + BASE + ",");
{% endif %}
            fw.write("\"cell_count\": " + CELLS + ",");
            fw.write("\"iters\": " + ITERS + ",");
            fw.write("\"elapsed_sec\": " + String.format("%.1f", elapsed / 1000.0) + ",");
            fw.write("\"mach\": " + {{ mach }} + ",");
            fw.write("\"aoa_deg\": " + {{ alpha_deg }} + "");
            // Append force coefficients if available
            try {
                fw.write(",");
                fw.write("\"cl\": " + forceReport.getLiftCoefficient().getValue() + ",");
                fw.write("\"cd\": " + forceReport.getDragCoefficient().getValue() + "");
            } catch (Exception fe) {
                fw.write(",");
                fw.write("\"cl_error\": \"unavailable\"" + "");
            }
            fw.write("}");
            fw.close();
            sim.println("Mesh convergence summary written to mesh_conv_summary.json");
        } catch (Exception je) {
            sim.println("WARNING: summary JSON export failed: " + je.getMessage());
        }

        sim.saveState(resolvePath("{{ case_dir }}/result.sim"));
        sim.println("NACA0012 simulation completed: {{ case_id }} (cells=" + CELLS
            + " elapsed=" + String.format("%.1f", elapsed / 1000.0) + "s)");
    }

    // --- Boundary detection helpers (auto-mesh regions may have different names) ---
    Boundary findWallBoundary(Region region) {
        // Try common naming conventions
        Boundary b = region.getBoundaryManager().getBoundary("airfoil");
        if (b != null) return b;
        b = region.getBoundaryManager().getBoundary("wall");
        if (b != null) return b;
        b = region.getBoundaryManager().getBoundary("NACA0012");
        if (b != null) return b;
        // Fallback: scan all boundaries for the first wall-type
        Iterator<Boundary> it = region.getBoundaryManager().getObjects().iterator();
        while (it.hasNext()) {
            Boundary candidate = it.next();
            String name = candidate.getPresentationName().toLowerCase();
            if (name.contains("wall") || name.contains("airfoil") || name.contains("naca")) {
                return candidate;
            }
        }
        sim().println("WARNING: no wall boundary found for NACA0012");
        return null;
    }

    Boundary findFarfieldBoundary(Region region) {
        Boundary b = region.getBoundaryManager().getBoundary("farfield");
        if (b != null) return b;
        b = region.getBoundaryManager().getBoundary("freestream");
        if (b != null) return b;
        b = region.getBoundaryManager().getBoundary("inlet");
        if (b != null) return b;
        Iterator<Boundary> it = region.getBoundaryManager().getObjects().iterator();
        while (it.hasNext()) {
            Boundary candidate = it.next();
            String name = candidate.getPresentationName().toLowerCase();
            if (name.contains("far") || name.contains("free") || name.contains("inlet")) {
                return candidate;
            }
        }
        sim().println("WARNING: no farfield boundary found for NACA0012");
        return null;
    }

    Simulation sim() { return getActiveSimulation(); }
}
