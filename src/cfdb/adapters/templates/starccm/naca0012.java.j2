                sim.saveState(resolvePath("{{ case_dir }}/result.sim"));
                sim.println("Simulation saved for case: {{ case_id }}");
                return;
            }
            // Export via Simulation operations
            sim.getReportManager().exportMonitor(forceReport,
                resolvePath("{{ case_dir }}/forces.csv"), ",");
            sim.println("Forces exported to forces.csv");
        } catch (Exception e) {
            sim.println("Warning: force CSV export failed: " + e.getMessage());
        }

        sim.saveState(resolvePath("{{ case_dir }}/result.sim"));
        sim.println("NACA0012 simulation completed: {{ case_id }}");
