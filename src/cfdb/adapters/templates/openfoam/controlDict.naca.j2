Description
    NACA0012 controlDict for simpleFoam (steady RANS-SA).

    Renders Jinja2 variables from SolverConfig.parameters:
      nu, u_inf, l_ref, alpha_deg, n_iter

\*---------------------------------------------------------------------------*/

 FoamFile
 {
     version     2.0;
     format      ascii;
     class       dictionary;
     object      controlDict;
 }

application     simpleFoam;

startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         {{ n_iter }};
deltaT          1;

writeControl    timeStep;
writeInterval   100;
purgeWrite      3;
writeFormat     ascii;
writePrecision  6;
writeCompression off;

timeFormat      general;
timePrecision   6;

runTimeModifiable true;

functions
{
    forces
    {
        // forceCoeffs rotates the force onto wind axes (liftDir/dragDir) and
        // normalises by magUInf/lRef/Aref internally, writing Cl/Cd directly
        // to coefficient.dat. Aref = chord x 2D span thickness (0.1 m) so the
        // result is a sectional (per-unit-span) coefficient.
        type            forceCoeffs;
        libs            ("libforces.so");
        writeControl    timeStep;
        writeInterval   50;

        patches         (airfoil);
        rho             rhoInf;
        log             yes;

        rhoInf          1.225;
        CofR            (0.25 0 0);
        liftDir         ({{ lift_dir_x }} {{ lift_dir_y }} 0);
        dragDir         ({{ drag_dir_x }} {{ drag_dir_y }} 0);
        pitchAxis       (0 0 1);
        magUInf         {{ u_inf }};
        lRef            {{ l_ref }};
        Aref            {{ a_ref }};
    }

    fieldAverage
    {
        type            fieldAverage;
        libs            ("libfieldFunctionObjects.so");
        writeControl    writeTime;
        fields
        (
            U
            {
                mean        on;
                prime2Mean  off;
                base        time;
            }
            p
            {
                mean        on;
                prime2Mean  off;
                base        time;
            }
        );
    }

    cpSurface
    {
        // Samples kinematic pressure on the airfoil patch at the final
        // iteration (raw x-y-z-p rows). The adapter converts to
        // Cp = p / (0.5 * u_inf^2) (simpleFoam p is kinematic, freestream
        // reference 0) and resamples the upper surface onto the case's
        // reference x/c grid for the curve_l2 gate.
        type            surfaces;
        libs            ("libsampling.so");
        writeControl    onEnd;
        surfaceFormat   raw;
        fields          (p);
        interpolationScheme cell;
        surfaces
        {
            airfoilSurface
            {
                type        patch;
                patches     (airfoil);
                interpolate false;
            }
        }
    }
}

