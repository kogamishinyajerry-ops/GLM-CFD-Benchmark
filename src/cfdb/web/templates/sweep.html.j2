{% extends "base.html.j2" %}
{% block title %}Sweep — CFD-Benchmark{% endblock %}

{% block content %}
<h1 style="color: var(--db-primary); margin-bottom: 0.75rem;">Sweep Report</h1>

{% if show_form %}
<div class="card">
    <p style="margin-bottom: 1rem; color: var(--db-muted);">
        View a multi-solver comparison for all runs matching a case ID prefix.
    </p>
    <form method="get" action="/sweep">
        <div class="form-group">
            <label for="case_prefix">Case ID Prefix</label>
            <input type="text" name="case_prefix" id="case_prefix"
                   placeholder="e.g. naca0012" required
                   style="font-family: monospace;">
        </div>
        <div class="form-group">
            <label>
                <input type="checkbox" name="polar" value="1">
                Include polar curves (requires cl/cd QoIs)
            </label>
        </div>
        <button type="submit" class="btn btn-primary">Generate Sweep Report</button>
    </form>
    {% if error %}
    <div class="error-box" style="margin-top: 1rem;">{{ error }}</div>
    {% endif %}
</div>
{% endif %}

{% if not show_form %}
<div style="margin-bottom: 0.75rem;">
    <a href="/sweep" style="color: var(--db-primary); text-decoration: none;">&larr; New Sweep</a>
    <span style="color: var(--db-muted); margin-left: 1rem;">
        Prefix: <code>{{ case_prefix }}</code> &mdash; {{ manifests|length }} run(s)
    </span>
</div>

{# Run Summary Table #}
<div class="card">
    <div class="card-header">Run Summary</div>
    {% if manifests %}
    <table>
        <thead>
            <tr>
                <th>Run ID</th>
                <th>Case</th>
                <th>Solver</th>
                <th>Status</th>
                <th>Wall (s)</th>
                <th>α (deg)</th>
                <th>Overall</th>
            </tr>
        </thead>
        <tbody>
            {% for m in manifests %}
            {% set met = metrics_list[loop.index0] %}
            {% set alpha = m.cli_args.get('alpha') if m.cli_args else none %}
            <tr>
                <td><a href="/runs/{{ m.run_id }}" style="font-family: monospace; font-size: 0.85rem; color: var(--db-primary);">{{ m.run_id[:25] }}...</a></td>
                <td>{{ m.case_id }}</td>
                <td>{{ m.solver }}</td>
                <td><span class="badge badge-{{ m.status }}">{{ m.status }}</span></td>
                <td>{{ "%.3f"|format(m.timing.wall_time_sec) }}</td>
                <td>{{ alpha if alpha else '—' }}</td>
                <td><span class="badge" style="background-color: {{ status_color(met.overall_status) }};">{{ met.overall_status }}</span></td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <p style="color: var(--db-muted);">No runs found.</p>
    {% endif %}
</div>

{# QoI Relative Errors Table #}
{% if sweep_qoi_names %}
<div class="card">
    <div class="card-header">QoI Relative Errors</div>
    <table>
        <thead>
            <tr>
                <th>Case</th>
                <th>Solver</th>
                {% for qn in sweep_qoi_names %}
                <th>{{ qn }}</th>
                {% endfor %}
            </tr>
        </thead>
        <tbody>
            {% for m in manifests %}
            {% set met = metrics_list[loop.index0] %}
            <tr>
                <td>{{ m.case_id }}</td>
                <td>{{ m.solver }}</td>
                {% for qn in sweep_qoi_names %}
                {% set val = met.qoi_relative_errors.get(qn) %}
                <td>{{ "%.4e"|format(val) if val is not none else '<span class="text-na">—</span>'|safe }}</td>
                {% endfor %}
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

{# Polar SVG #}
{% if polar_svg %}
<div class="card">
    <div class="card-header">Polar Curves (Cl-α / Cd-α)</div>
    <div class="svg-container">
        {{ polar_svg | safe }}
    </div>
</div>
{% endif %}
{% endif %}
{% endblock %}
