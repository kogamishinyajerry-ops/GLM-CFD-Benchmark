// StarCCM+ macro auto-generated by cfdb StarCCMAdapter
// Case: {{ case_id }}, Mach: {{ mach }}, Re: {{ reynolds }}, AoA: {{ alpha_deg }} deg
// Generated: auto

package macro;

import star.common.*;
import star.base.report.*;
import star.base.neo.*;
import star.flow.*;
import star.meshing.*;
import star.turbulence.*;

public class RunCase extends StarMacro {

    public void execute() {
        Simulation sim = getActiveSimulation();

        // --- 1. Import mesh ---
        sim.getMeshManager().importMesh(resolvePath("{{ case_dir }}/mesh.ccm"));
        sim.println("Mesh imported from: {{ case_dir }}/mesh.ccm");

        // --- 2. Set physics models ---
        {% if mach|float > 0.3 %}
        // Compressible ideal-gas RANS-SA
        sim.getPhysicsContinuumManager().getContinuum(0)
            .enable(CompressibleModel.class);
        sim.getPhysicsContinuumManager().getContinuum(0)
            .enable(GasModel.class);
        sim.getPhysicsContinuumManager().getContinuum(0)
            .getModelManager().getModel(GasModel.class)
            .getMaterialManager().setConstantDensity(false);
        {% else %}
        // Incompressible segregated RANS-SA
        sim.getPhysicsContinuumManager().getContinuum(0)
            .enable(SegregatedFlowModel.class);
        sim.getPhysicsContinuumManager().getContinuum(0)
            .getModelManager().getModel(SegregatedFlowModel.class)
            .setVelocities({{ u_cos }}, {{ v_sin }}, 0.0);
        {% endif %}

        // Turbulence: Spalart-Allmaras
        sim.getPhysicsContinuumManager().getContinuum(0)
            .enable(SpalartAllmarasTurbulence.class);
        sim.getPhysicsContinuumManager().getContinuum(0)
            .enable(RansTurbulenceModel.class);
        sim.getPhysicsContinuumManager().getContinuum(0)
            .enable(SteadyModel.class);
        sim.getPhysicsContinuumManager().getContinuum(0)
            .enable(ThreeDimensionalModel.class);

        // --- 3. Set boundary conditions ---
        Region region = sim.getRegionManager().getRegion("Region");
        // Set velocity at farfield/freestream boundaries
        Boundary farfield = region.getBoundaryManager().getBoundary("farfield");
        if (farfield != null) {
            farfield.getValues().get(Velocity.class).setComponents({{ u_cos }}, {{ v_sin }}, 0.0);
        }

        // Wall: no-slip, smooth
        Boundary wall = region.getBoundaryManager().getBoundary("wall");
        if (wall != null) {
            wall.getConditions().get(WallShearStressOption.class)
                .setSelected(WallShearStressOption.NO_SLIP);
        }

        // --- 4. Set reference values for Cd/Cl computation ---
        ReferenceValues refVals = sim.getReferenceValues();
        refVals.setReferenceVelocity({{ u_inf }});
        refVals.setReferenceArea(1.0);
        refVals.setReferenceDensity(1.225);

        // --- 5. Create monitors and reports ---
        // Residuals monitor
        MonitorPlot residualsPlot = sim.getPlotManager()
            .createMonitorPlot("Residuals Monitor");
        ResidualMonitorIterator resIt = sim.getMonitorManager()
            .getResidualMonitorManager().getObjects().iterator();
        while (resIt.hasNext()) {
            ResidualMonitor rm = resIt.next();
            residualsPlot.add(rm.createDataSet());
        }

        // Force coefficient report on wall
        ForceCoefficientReport forceReport = sim.getReportManager()
            .createReport(ForceCoefficientReport.class);
        forceReport.setPresentationName("Force Coefficient");
        forceReport.getParts().setObjects(wall);

        // Force coefficient monitor
        Monitor forceMonitor = forceReport.createMonitor();
        forceMonitor.getMonitorPlot().setTitle("Force Coefficients");

        // --- 6. Set stopping criteria ---
        sim.getSolverStoppingCriterionManager()
           .getSolverStoppingCriterion("Maximum Steps")
           .setMaximumNumberSteps({{ n_iter }});

        // --- 7. Run solver ---
        sim.getSimulationIterator().run();

        // --- 8. Write reports to CSV ---
        sim.saveState(resolvePath("{{ case_dir }}/result.sim"));
        sim.println("Solver finished for case: {{ case_id }}");
    }
}
