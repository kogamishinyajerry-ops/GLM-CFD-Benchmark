Description
    Discretization schemes for simpleFoam RANS on the NACA0012 airfoil case.
    Supports both SA (SpalartAllmaras) and SST (kOmegaSST) via Jinja2
    variable `turbulence_model`. The turbulence-specific grad/div entries
    are rendered only for the active model.

\*---------------------------------------------------------------------------*/

 FoamFile
 {
     version     2.0;
     format      ascii;
     class       dictionary;
     object      fvSchemes;
 }

ddtSchemes
{
    default         steadyState;
}

gradSchemes
{
    default         Gauss linear;
    grad(U)         Gauss linear;
{%- if turbulence_model == "kOmegaSST" %}
    grad(k)         cellLimited Gauss linear 1;
    grad(omega)     cellLimited Gauss linear 1;
{%- else %}
    grad(nuTilda)   cellLimited Gauss linear 1;
{%- endif %}
}

divSchemes
{
    default         none;
    // Second-order upwind for Cl/Cd accuracy on validation cases (Ladson 1988).
    // First-order pure upwind was used during early stability tuning but
    // introduces excessive numerical viscosity, under-predicting Cl slope
    // and over-predicting Cd by >10% at α=10/15°. linearUpwind needs the
    // matching grad() entry above.
    div(phi,U)      Gauss linearUpwind grad(U);
{%- if turbulence_model == "kOmegaSST" %}
    div(phi,k)      bounded Gauss linearUpwind grad(k);
    div(phi,omega)  bounded Gauss linearUpwind grad(omega);
{%- else %}
    // P3-tail note (2026-06-17): SA stabilization attempts via upwind on
    // nuTilda did not prevent step-200 divergence on coarse high-y+ mesh.
    // Root cause is mesh/relaxation, not scheme order. linearUpwind retained.
    div(phi,nuTilda) bounded Gauss linearUpwind grad(nuTilda);
{%- endif %}
    div((nuEff*dev2(T(grad(U))))) Gauss linear;
}

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}

wallDist
{
    method meshWave;
}

// Reynolds: {{ reynolds }}, nu: {{ nu }}

