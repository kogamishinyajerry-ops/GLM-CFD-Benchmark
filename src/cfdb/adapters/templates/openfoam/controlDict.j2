FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     icoFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         0.5;

deltaT          0.005;

writeControl    timeStep;

writeInterval   20;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

functions
{
    probes
    {
        type            probes;
        libs            (fieldFunctionObjects);

        writeControl    timeStep;
        writeInterval   1;

        probeLocations
        (
            (0.5 0.05 0)
            (0.5 0.10 0)
            (0.5 0.15 0)
            (0.5 0.20 0)
            (0.5 0.25 0)
            (0.5 0.30 0)
            (0.5 0.35 0)
            (0.5 0.40 0)
            (0.5 0.45 0)
            (0.5 0.50 0)
            (0.5 0.55 0)
            (0.5 0.60 0)
            (0.5 0.65 0)
            (0.5 0.70 0)
            (0.5 0.75 0)
            (0.5 0.80 0)
            (0.5 0.85 0)
            (0.5 0.90 0)
            (0.5 0.95 0)
        );

        fields          ( U );
    }
}

// Reynolds number: {{ reynolds }}
// Kinematic viscosity: {{ nu }}

