Description
    snappyHexMeshDict for NACA0012 airfoil mesh refinement.

    Refines the background blockMesh around the airfoil STL and adds
    boundary layer cells (prism layers) on the airfoil surface.

    Rendered with Jinja2 by the OpenFOAM adapter.

\*---------------------------------------------------------------------------*/

 FoamFile
 {
     version     2.0;
     format      ascii;
     class       dictionary;
     object      snappyHexMeshDict;
 }

castellatedMesh on;
snap            on;
addLayers       on;

geometry
{
    naca0012.stl
    {
        type triSurfaceMesh;
        name airfoil;
    }

    refinementBox
    {
        type searchableBox;
        min (-0.2 -0.2 -0.1);
        max ( 1.2  0.2  0.1);
    }
};

castellatedMeshControls
{
    maxLocalCells 200000;
    maxGlobalCells 500000;
    minRefinementCells 0;

    nCellsBetweenLevels 2;

    features
    (
    );

    refinementSurfaces
    {
        airfoil
        {
            level (4 4);
            patchInfo { type wall; }
        }
    }

    resolveFeatureAngle 30;

    refinementRegions
    {
        refinementBox
        {
            mode inside;
            levels ((1E15 2));
        }
    }

    locationInMesh (0.5 0.0 0.0);

    allowFreeStandingZoneFaces true;
}

snapControls
{
    nSmoothPatch 3;
    tolerance 2.0;
    nSolveIter 30;
    nRelaxIter 5;
    nFeatureSnapIter 10;
    implicitFeatureSnap false;
    explicitFeatureSnap true;
    multiRegionFeatureSnap false;
}

addLayersControls
{
    relativeSizes true;

    // Use finalAndExpansion model: specify final layer thickness (relative
    // to near-wall surface cell size) and expansion ratio. Target y+ ~ 30-50
    // for wall-function SA.
    thicknessModel finalAndExpansion;

    layers
    {
        "airfoil.*"
        {
            nSurfaceLayers 8;
        }
    }

    expansionRatio 1.2;
    finalLayerThickness 0.5;
    minThickness 0.1;

    nGrow 0;
    featureAngle 60;
    nRelaxIter 5;
    nSmoothSurfaceNormals 1;
    nSmoothThickness 10;
    nSmoothNormals 3;
    maxFaceThicknessRatio 0.5;
    maxThicknessToMedialRatio 0.3;
    minMedialAxisAngle 90;
    slipFeatureAngle 30;
    nBufferCellsNoExtrude 0;
    nLayerIter 50;
    nRelaxedIter 20;
}

meshQualityControls
{
    #includeEtc "caseDicts/meshQualityDict"

    //- Amount by which to scale back the motion if the mesh becomes invalid
    errorReduction 0.75;

    //- Number of smoothing iterations for the error-based motion
    nSmoothScale 4;

    //- Controls the relaxation of the mesh motion solver
    relaxed
    {
        maxNonOrtho 75;
    }
}

writeFlags
(
    scalarLevels
    layerSets
    layerFields
);

mergeTolerance 1e-6;

