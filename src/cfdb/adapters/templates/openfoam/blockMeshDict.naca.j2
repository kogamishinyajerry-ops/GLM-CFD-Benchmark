Description
    NACA0012 background hex mesh — single rectangular block.

    snappyHexMesh does all the airfoil-related refinement and patch
    assignment; blockMesh only generates the uniform background grid.

\*---------------------------------------------------------------------------*/

 FoamFile
 {
     version     2.0;
     format      ascii;
     class       dictionary;
     object      blockMeshDict;
 }

scale 1;

// NACA0012 chord = 1.0, domain extends ~10 chords upstream / 12 downstream.
vertices
(
    (-10.0 -10.0  -0.05)    // 0
    ( 12.0 -10.0  -0.05)    // 1
    ( 12.0  10.0  -0.05)    // 2
    (-10.0  10.0  -0.05)    // 3

    (-10.0 -10.0   0.05)    // 4
    ( 12.0 -10.0   0.05)    // 5
    ( 12.0  10.0   0.05)    // 6
    (-10.0  10.0   0.05)    // 7
);

blocks
(
    // P3.1-SA Phase 2: moderate denser background (120x90 vs original 100x80)
    hex (0 1 2 3 4 5 6 7) (120 90 1) simpleGrading (1 1 1)
);

edges
(
);

boundary
(
    farfield
    {
        type patch;
        physicalType inlet;
        faces
        (
            (0 1 5 4)   // bottom
            (1 2 6 5)   // right
            (2 3 7 6)   // top
            (3 0 4 7)   // left
        );
    }
);

defaultPatch
{
    type empty;
    name frontAndBack;
}

