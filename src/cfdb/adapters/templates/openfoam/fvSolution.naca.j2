Description
    SIMPLE algorithm + under-relaxation for NACA0012 (simpleFoam RANS-SA).

    Under-relaxation: p 0.2, U 0.3, nuTilda 0.1 — tuned for SA stability on
    high-y+ snappyHexMesh grids. nuTilda relax=0.1 is the primary SA divergence
    fix (P3.1-SA Phase 1); U relax=0.3 prevents momentum overshoot at high-α.

\*---------------------------------------------------------------------------*/

 FoamFile
 {
     version     2.0;
     format      ascii;
     class       dictionary;
     object      fvSolution;
 }

solvers
{
    p
    {
        solver          GAMG;
        tolerance       1e-08;
        relTol          0.01;
        smoother        GaussSeidel;
        nPreSweeps      0;
        nPostSweeps     2;
        cacheAgglomeration true;
        nCellsInCoarsestLevel 10;
        agglomerator    faceAreaPair;
        mergeLevels     1;
    }
    U
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-08;
        relTol          0.01;
    }
    nuTilda
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-7;
        relTol          0.001;
    }
}

SIMPLE
{
    momentumPredictor yes;
    nNonOrthogonalCorrectors 3;
    pRefCell        0;
    pRefValue       0;

    residualControl
    {
        U               1e-5;
        p               1e-5;
        // nuTilda intentionally NOT in residualControl — SA working variable
        // converges very slowly and its residual plateau at ~0.06 is normal
        // for high-y+ meshes. Forcing nuTilda convergence via residualControl
        // causes early SIMPLE termination with un-converged turbulence.
    }
}

relaxationFactors
{
    equations
    {
        U               0.3;
        p               0.2;
        nuTilda         0.1;
    }
}

