package macro;

import star.common.*;
import star.base.report.*;
import star.flow.*;
import star.turbulence.*;

public class RunCase extends StarMacro {

    public void execute() {
        Simulation sim = getActiveSimulation();

        // --- 1. Import mesh ---
        sim.getMeshManager().importMesh(resolvePath("{{ case_dir }}/mesh.ccm"));
        sim.println("NACA0012 mesh imported");

        // --- 2. Physics: Compressible RANS-SA ---
        PhysicsContinuum phys = sim.getPhysicsContinuumManager().getContinuum(0);
        phys.enable(GasModel.class);
        phys.enable(CoupledFlowModel.class);
        phys.enable(SteadyModel.class);
        phys.enable(TurbulentModel.class);
        phys.enable(RansTurbulenceModel.class);
        phys.enable(SpalartAllmarasTurbulence.class);
        phys.enable(IdealGasModel.class);

        // Freestream velocity from Mach
        sim.getConditions().get(Velocity.class).setComponents({{ u_cos }}, {{ v_sin }}, 0.0);
        sim.getConditions().get(MachNumber.class).setValue({{ mach }});
        sim.getConditions().get(ReynoldsNumber.class).setValue({{ reynolds }});

        // --- 3. Boundary conditions ---
        Region region = sim.getRegionManager().getRegion("Region");
        Boundary wall = region.getBoundaryManager().getBoundary("airfoil");
        if (wall != null) {
            wall.getConditions().get(WallShearStressOption.class)
                .setSelected(WallShearStressOption.NO_SLIP);
        }
        Boundary farfield = region.getBoundaryManager().getBoundary("farfield");
        if (farfield != null) {
            farfield.setType(FreestreamBoundary.class);
        }

        // --- 4. Reference values ---
        ReferenceValues refVals = sim.getReferenceValues();
        refVals.setReferenceVelocity({{ u_inf }});
        refVals.setReferenceArea(1.0);
        refVals.setReferenceDensity(1.225);

        // --- 5. Force coefficient report on airfoil ---
        ForceCoefficientReport forceReport = sim.getReportManager()
            .createReport(ForceCoefficientReport.class);
        forceReport.setPresentationName("Force Coefficient NACA0012");
        forceReport.getParts().setObjects(wall);

        // Create monitors for Cl, Cd
        forceReport.getForceCoefficientMonitor().setPresentationName("Cl/Cd Monitor");

        // Create CSV export for force history
        MonitorPlot forcePlot = sim.getPlotManager()
            .createMonitorPlot("Force History");
        forcePlot.add(forceReport.getForceCoefficientMonitor().createDataSet());

        // --- 6. Residual monitors ---
        MonitorPlot residualPlot = sim.getPlotManager()
            .createMonitorPlot("Residuals");
        ResidualMonitorIterator resIt = sim.getMonitorManager()
            .getResidualMonitorManager().getObjects().iterator();
        while (resIt.hasNext()) {
            ResidualMonitor rm = resIt.next();
            residualPlot.add(rm.createDataSet());
        }

        // --- 7. Stopping criteria ---
        sim.getSolverStoppingCriterionManager()
           .getSolverStoppingCriterion("Maximum Steps")
           .setMaximumNumberSteps({{ n_iter }});

        // --- 8. Run solver ---
        sim.getSimulationIterator().run();

