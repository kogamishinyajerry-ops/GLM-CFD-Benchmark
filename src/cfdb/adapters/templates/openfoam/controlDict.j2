FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     icoFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         {{ end_time | default(0.5) }};

deltaT          {{ delta_t | default(0.005) }};

writeControl    timeStep;

writeInterval   {{ write_interval | default(100) }};

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

functions
{
    probes
    {
        type            probes;
        libs            (fieldFunctionObjects);

        writeControl    timeStep;
        writeInterval   1;

        probeLocations
        (
            (0.05 0.005 0.005)
            (0.05 0.010 0.005)
            (0.05 0.015 0.005)
            (0.05 0.020 0.005)
            (0.05 0.025 0.005)
            (0.05 0.030 0.005)
            (0.05 0.035 0.005)
            (0.05 0.040 0.005)
            (0.05 0.045 0.005)
            (0.05 0.050 0.005)
            (0.05 0.055 0.005)
            (0.05 0.060 0.005)
            (0.05 0.065 0.005)
            (0.05 0.070 0.005)
            (0.05 0.075 0.005)
            (0.05 0.080 0.005)
            (0.05 0.085 0.005)
            (0.05 0.090 0.005)
            (0.05 0.095 0.005)
        );

        fields          ( U );
    }
}

// Reynolds number: {{ reynolds }}
// Kinematic viscosity: {{ nu }}

